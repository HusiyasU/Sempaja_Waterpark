{
  "version": 2,
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    },
    {
      "src": "**/*.php",
      "use": "vercel-php"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*).php", "dest": "/$1.php" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}