{
  "version": 2,
  "framework": null,
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.7.5"
    }
  },
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "**/*.php",
      "use": "vercel-php@0.7.5"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/api/(.*).php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(.*).php",
      "dest": "/$1.php"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}